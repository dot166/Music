<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Widget.Music.TextView.Item.Primary" parent="Widget.AppCompat.TextView">
        <item name="android:textAppearance">@style/TextAppearance.Music.TitleMedium</item>
        <item name="android:textColor">?android:attr/textColorPrimary</item>
    </style>

    <style name="Widget.Music.TextView.Item.Secondary" parent="Widget.AppCompat.TextView">
        <item name="android:textAppearance">@style/TextAppearance.Music.BodyMedium</item>
        <item name="android:textColor">?android:attr/textColorSecondary</item>
    </style>

    <style name="TextAppearance.Music.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">-0.01125</item>
    </style>

    <style name="TextAppearance.Music.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">-0.0064285714</item>
    </style>

    <style name="Widget.Music.Button.Playback.Toggle" parent="Widget.Material3Expressive.Button.IconButton.Outlined">
        <item name="android:checkable">true</item>
        <item name="iconTint">@color/sel_checkable_icon</item>
        <item name="strokeColor">@color/sel_checkable_outline</item>
        <item name="backgroundTint">?attr/colorSurface</item>
    </style>

    <style name="Widget.Music.Button.Playback.Skip" parent="Widget.Material3Expressive.Button.IconButton.Tonal" />

    <style name="Widget.Music.Button.Playback.PlayPause" parent="Widget.Material3Expressive.Button.IconButton.Tonal">
        <item name="android:checkable">true</item>
    </style>

</resources>